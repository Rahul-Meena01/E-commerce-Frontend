# Server Configuration
PORT=3000
NODE_ENV=development

# Database Connection (MongoDB URI)
MONGO_URI=mongodb://localhost:27017/loft

# JWT Authentication
JWT_SECRET=your_jwt_secret_key_here
ADMIN_SECRET=your_admin_secret_key_here

# Frontend / Client URLs (comma separated)
CLIENT_URL=http://localhost:5173,http://localhost:5174

# Payment Configuration
PAYMENT_CURRENCY=INR
CURRENCY_SYMBOL=₹

# Stripe Credentials (Optional)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Razorpay Credentials (Optional)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# SMTP / Email Configuration (Optional)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM="LOFT E-commerce" <noreply@loft-premium.com>
